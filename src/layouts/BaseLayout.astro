---
// src/layouts/BaseLayout.astro
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import SEOHead from '@/components/common/SEOHead.astro';
import type { SEOProps } from '@/lib/seo';
import type { Lang } from '@/i18n/ui';
import '@/styles/global.css';

interface Props extends SEOProps {}

const props = Astro.props;
const lang = props.lang as Lang;
---

<!doctype html>
<html lang={props.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#58A6FF" />
    <link rel="icon" type="image/png" href="/favicon-new.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <SEOHead {...props} />
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3397126124922474" crossorigin="anonymous"></script>
    <slot name="head" />
    <script is:inline>
      (function(){try{var t=localStorage.getItem('theme');if(t==='light'||(t===null&&matchMedia('(prefers-color-scheme:light)').matches)){document.documentElement.classList.add('light')}}catch(e){}})();
    </script>
  </head>
  <body class="overflow-x-hidden">
    <Header lang={lang} />
    <main class="mx-auto max-w-7xl px-4 py-8">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
