---
// src/components/common/ToolCard.astro
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
}

const { title, description, href, icon = '{ }' } = Astro.props;
---

<a
  href={href}
  class="group block rounded-lg border border-[var(--border-primary)] bg-[var(--bg-secondary)] p-4 transition-all hover:border-[var(--accent-blue)]/50 hover:shadow-lg hover:shadow-[var(--accent-blue)]/5"
>
  <div class="flex items-start gap-3">
    <span class="text-lg font-mono text-[var(--accent-blue)]">{icon}</span>
    <div>
      <h3 class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[var(--accent-blue)] transition-colors">
        {title}
      </h3>
      <p class="mt-1 text-xs text-[var(--text-secondary)] line-clamp-2">{description}</p>
    </div>
  </div>
</a>
