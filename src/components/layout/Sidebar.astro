---
// src/components/layout/Sidebar.astro
import { type Lang } from '@/i18n/ui';
import { getCategories, getCommon } from '@/i18n/t';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const categories = getCategories(lang);
const common = getCommon(lang);

const catList = [
  { slug: 'json', icon: '{ }' },
  { slug: 'encrypt', icon: '🔐' },
  { slug: 'format', icon: '📐' },
  { slug: 'encode', icon: '🔄' },
  { slug: 'qr', icon: '📱' },
  { slug: 'webmaster', icon: '🌐' },
  { slug: 'frontend', icon: '🎨' },
  { slug: 'life', icon: '🕐' },
  { slug: 'other', icon: '🛠️' },
];
---

<nav class="sticky top-20 space-y-4">
  <div>
    <h3 class="mb-2 text-xs font-semibold uppercase tracking-wider text-[var(--text-tertiary)]">
      {common.categories}
    </h3>
    <ul class="space-y-1">
      {catList.map((cat) => {
        const catData = categories[cat.slug];
        return (
          <li>
            <a
              href={`/${lang}/category/${cat.slug}`}
              class="flex items-center gap-2 rounded-md px-3 py-1.5 text-sm text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] hover:text-[var(--text-primary)] transition-colors"
            >
              <span>{cat.icon}</span>
              <span>{catData?.name ?? cat.slug}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</nav>
