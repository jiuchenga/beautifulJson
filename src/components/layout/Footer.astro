---
// src/components/layout/Footer.astro
import { type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getIndexPage, getTools } from '@/i18n/t';

interface Props {
  lang?: Lang;
}

const lang = (Astro.props.lang || 'en') as Lang;
const common = getCommon(lang);
const categories = getCategories(lang);
const tools = getTools(lang);
const indexPage = getIndexPage(lang);

const footerLinks = [
  {
    title: common.popularTools ?? 'Popular Tools',
    links: [
      { label: tools['json/formatter']?.name ?? 'JSON Formatter', href: `/${lang}/json/formatter` },
      { label: tools['encrypt/aes']?.name ?? 'AES Encrypt', href: `/${lang}/encrypt/aes` },
      { label: tools['qr/generate']?.name ?? 'QR Code Generator', href: `/${lang}/qr/generate` },
      { label: tools['encrypt/base64']?.name ?? 'Base64', href: `/${lang}/encrypt/base64` },
    ],
  },
  {
    title: common.categories ?? 'Categories',
    links: [
      { label: categories.json?.name ?? 'JSON Tools', href: `/${lang}/category/json` },
      { label: categories.encrypt?.name ?? 'Encryption', href: `/${lang}/category/encrypt` },
      { label: categories.webmaster?.name ?? 'Webmaster', href: `/${lang}/category/webmaster` },
      { label: categories.qr?.name ?? 'QR Code', href: `/${lang}/category/qr` },
    ],
  },
  {
    title: common.resources ?? 'Resources',
    links: [
      { label: common.blog ?? 'Blog', href: `/${lang}/blog` },
      { label: common.tutorials ?? 'Tutorials', href: `/${lang}/tutorials` },
    ],
  },
];
---

<footer class="border-t border-[var(--border-primary)] bg-[var(--bg-secondary)] mt-16">
  <div class="mx-auto max-w-7xl px-4 py-12">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-4">
      <!-- Brand -->
      <div>
        <a href={`/${lang}/`} class="flex items-center gap-2 text-lg font-bold text-[var(--text-primary)] hover:no-underline">
          <span>beautiful<span class="text-[var(--accent-blue)]">{'{json}'}</span></span>
        </a>
        <p class="mt-3 text-sm text-[var(--text-secondary)]">
          {indexPage.heroSubtitle}
        </p>
      </div>

      <!-- Link Columns -->
      {footerLinks.map((section) => (
        <div>
          <h3 class="text-sm font-semibold text-[var(--text-primary)]">{section.title}</h3>
          <ul class="mt-3 space-y-2">
            {section.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-[var(--text-secondary)] hover:text-accent-blue transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 border-t border-[var(--border-secondary)] pt-6 text-center text-sm text-[var(--text-tertiary)]">
      <p>&copy; {new Date().getFullYear()} BeautifulJSON. {common.copyright ?? 'All tools are free and open source.'}</p>
    </div>
  </div>
</footer>
