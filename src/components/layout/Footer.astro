---
// src/components/layout/Footer.astro
import { type Lang } from '@/i18n/ui';

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang || 'en';

const footerLinks = [
  {
    title: 'Popular Tools',
    links: [
      { label: 'JSON Formatter', href: `/${lang}/json/formatter` },
      { label: 'AES Encrypt/Decrypt', href: `/${lang}/encrypt/aes` },
      { label: 'QR Code Generator', href: `/${lang}/qr/generator` },
      { label: 'Base64 Encode/Decode', href: `/${lang}/encrypt/base64` },
    ],
  },
  {
    title: 'Categories',
    links: [
      { label: 'JSON Tools', href: `/${lang}/category/json` },
      { label: 'Encryption', href: `/${lang}/category/encrypt` },
      { label: 'Webmaster', href: `/${lang}/category/webmaster` },
      { label: 'QR Code', href: `/${lang}/category/qr` },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Blog', href: `/${lang}/blog` },
      { label: 'Tutorials', href: `/${lang}/tutorials` },
      { label: 'API Docs', href: `/${lang}/api-docs` },
    ],
  },
];
---

<footer class="border-t border-[var(--border-primary)] bg-[var(--bg-secondary)] mt-16">
  <div class="mx-auto max-w-7xl px-4 py-12">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-4">
      <!-- Brand -->
      <div>
        <a href={`/${lang}/`} class="flex items-center gap-2 text-lg font-bold text-[var(--text-primary)] hover:no-underline">
          <span class="font-mono text-[var(--accent-blue)]">{'{ }'}</span>
          <span>DevToolkit</span>
        </a>
        <p class="mt-3 text-sm text-[var(--text-secondary)]">
          160+ free online developer tools. No signup required. All processing happens in your browser.
        </p>
      </div>

      <!-- Link Columns -->
      {footerLinks.map((section) => (
        <div>
          <h3 class="text-sm font-semibold text-[var(--text-primary)]">{section.title}</h3>
          <ul class="mt-3 space-y-2">
            {section.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent-blue)] transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 border-t border-[var(--border-secondary)] pt-6 text-center text-sm text-[var(--text-tertiary)]">
      <p>&copy; {new Date().getFullYear()} DevToolkit. All tools are free and open source.</p>
    </div>
  </div>
</footer>
