---
import ToolLayout from '@/layouts/ToolLayout.astro';
import HashDigest from '@/components/tools/encrypt/HashDigest';

const breadcrumbs = [
  { name: 'Home', url: '/ko' },
  { name: 'Encryption', url: '/ko/category/encrypt' },
  { name: 'Hash / Digest', url: '/ko/encrypt/hash-digest' },
];
---

<ToolLayout
  title="Hash / Digest - Free Online Tool | DevToolkit"
  description="Generate hash digests with MD5, SHA-1, SHA-256, SHA-512, SHA-3, RIPEMD-160. Free online developer tool, no signup required."
  path="/encrypt/hash-digest"
  siteUrl="https://devtoolkit.com"
  lang="ko"
  toolName="Hash / Digest"
  toolDescription="Generate hash digests with MD5, SHA-1, SHA-256, SHA-512, SHA-3, RIPEMD-160"
  breadcrumbs={breadcrumbs}
>
  <HashDigest client:load />
</ToolLayout>
