---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsCompressEncrypt from '@/components/tools/encrypt/JsCompressEncrypt';

const breadcrumbs = [
  { name: 'Home', url: '/ko' },
  { name: 'Encryption', url: '/ko/category/encrypt' },
  { name: 'JS Encrypt / Compress', url: '/ko/encrypt/js-compress' },
];
---

<ToolLayout
  title="JS Encrypt / Compress - Free Online Tool | DevToolkit"
  description="Encrypt, compress, or decrypt JavaScript code. Free online developer tool, no signup required."
  path="/encrypt/js-compress"
  siteUrl="https://devtoolkit.com"
  lang="ko"
  toolName="JS Encrypt / Compress"
  toolDescription="Encrypt, compress, or decrypt JavaScript code"
  breadcrumbs={breadcrumbs}
>
  <JsCompressEncrypt client:load />
</ToolLayout>
