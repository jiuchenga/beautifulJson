---
import ToolLayout from '@/layouts/ToolLayout.astro';
import AsciiConverter from '@/components/tools/encrypt/AsciiConverter';

const breadcrumbs = [
  { name: 'Home', url: '/ko' },
  { name: 'Encryption', url: '/ko/category/encrypt' },
  { name: 'ASCII Converter', url: '/ko/encrypt/ascii' },
];
---

<ToolLayout
  title="ASCII Converter - Free Online Tool | DevToolkit"
  description="Convert between ASCII codes and text. Free online developer tool, no signup required."
  path="/encrypt/ascii"
  siteUrl="https://devtoolkit.com"
  lang="ko"
  toolName="ASCII Converter"
  toolDescription="Convert between ASCII codes and text"
  breadcrumbs={breadcrumbs}
>
  <AsciiConverter client:load />
</ToolLayout>
