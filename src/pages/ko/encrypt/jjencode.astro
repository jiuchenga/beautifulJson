---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsJJEncode from '@/components/tools/encrypt/JsJJEncode';

const breadcrumbs = [
  { name: 'Home', url: '/ko' },
  { name: 'Encryption', url: '/ko/category/encrypt' },
  { name: 'JS JJEncode Encrypt', url: '/ko/encrypt/jjencode' },
];
---

<ToolLayout
  title="JS JJEncode Encrypt - Free Online Tool | DevToolkit"
  description="Encode JavaScript with JJEncode pattern (irreversible). Free online developer tool, no signup required."
  path="/encrypt/jjencode"
  siteUrl="https://devtoolkit.com"
  lang="ko"
  toolName="JS JJEncode Encrypt"
  toolDescription="Encode JavaScript with JJEncode pattern (irreversible)"
  breadcrumbs={breadcrumbs}
>
  <JsJJEncode client:load />
</ToolLayout>
