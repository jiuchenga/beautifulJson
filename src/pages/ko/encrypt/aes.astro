---
import ToolLayout from '@/layouts/ToolLayout.astro';
import AesEncrypt from '@/components/tools/encrypt/AesEncrypt';

const breadcrumbs = [
  { name: 'Home', url: '/ko' },
  { name: 'Encryption', url: '/ko/category/encrypt' },
  { name: 'Encrypt / Decrypt', url: '/ko/encrypt/aes' },
];
---

<ToolLayout
  title="Encrypt / Decrypt - Free Online Tool | DevToolkit"
  description="Symmetric encryption with AES, DES, TripleDES, RC4, Rabbit, PBKDF2. Free online developer tool, no signup required."
  path="/encrypt/aes"
  siteUrl="https://devtoolkit.com"
  lang="ko"
  toolName="Encrypt / Decrypt"
  toolDescription="Symmetric encryption with AES, DES, TripleDES, RC4, Rabbit, PBKDF2"
  breadcrumbs={breadcrumbs}
>
  <AesEncrypt client:load />
</ToolLayout>
