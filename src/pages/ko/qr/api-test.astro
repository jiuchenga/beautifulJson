---
import ToolLayout from '@/layouts/ToolLayout.astro';
import QrCodeApiTest from '@/components/tools/qr/QrCodeApiTest';

const breadcrumbs = [
  { name: 'Home', url: '/ko' },
  { name: 'QR Code Tools', url: '/ko/category/qr' },
  { name: 'QR Code API Test', url: '/ko/qr/api-test' },
];
---

<ToolLayout
  title="QR Code API Test - Free Online Tool | DevToolkit"
  description="Generate QR codes with API-style parameters."
  path="/qr/api-test"
  siteUrl="https://devtoolkit.com"
  lang="ko"
  toolName="QR Code API Test"
  toolDescription="API-style QR code generation"
  breadcrumbs={breadcrumbs}
>
  <QrCodeApiTest client:load />
</ToolLayout>
