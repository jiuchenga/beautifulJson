---
import ToolLayout from '@/layouts/ToolLayout.astro';
import QrCodeKnowledge from '@/components/tools/qr/QrCodeKnowledge';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'QR Code Tools', url: '/ko/category/qr' },
  { name: 'QR Code Knowledge', url: '/ko/qr/knowledge' },
];
---

<ToolLayout
  title="QR Code Knowledge - Free Online Tool | DevToolkit"
  description="FAQ and encyclopedia about QR codes."
  path="/qr/knowledge"
  siteUrl="https://devtoolkit.com"
  lang="ko"
  toolName="QR Code Knowledge"
  toolDescription="QR code FAQ and encyclopedia"
  breadcrumbs={breadcrumbs}
>
  <QrCodeKnowledge client:load />
</ToolLayout>
