---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsonToCSharp from '@/components/tools/json/JsonToCSharp';

const breadcrumbs = [
  { name: 'Home', url: '/ko' },
  { name: 'JSON Tools', url: '/ko/category/json' },
  { name: 'JSON to C#', url: '/ko/json/to-csharp' },
];
---

<ToolLayout
  title="JSON to C# Class - Generate C# from JSON"
  description="Generate C# class from JSON data with Newtonsoft.Json attributes. Free online developer tool."
  path="/json/to-csharp"
  siteUrl="https://devtoolkit.com"
  lang="ko"
  toolName="JSON to C#"
  toolDescription="Generate C# class from JSON data with Newtonsoft.Json attributes"
  breadcrumbs={breadcrumbs}
>
  <JsonToCSharp client:load />
</ToolLayout>
