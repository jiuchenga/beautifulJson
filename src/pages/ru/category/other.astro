---
// src/pages/en/category/other.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/common/Breadcrumb.astro';
import ToolCard from '@/components/common/ToolCard.astro';

const breadcrumbs = [
  { name: 'Home', url: '/ru' },
  { name: 'Other Tools', url: '/ru/category/other' },
];

const tools = [
  { title: 'Password Generator', description: 'Secure password generation', href: '/ru/other/password-generator', icon: '🔑' },
  { title: 'Cron Expression Generator', description: 'Cron expression builder', href: '/ru/other/cron-generator', icon: '⏰' },
];
---

<BaseLayout
  title="Other Tools - Free Online Developer Utilities"
  description="Free online developer tools: password generator, cron expression generator and more."
  path="/category/other"
  siteUrl="https://devtoolkit.com"
  lang="ru"
>
  <Breadcrumb items={breadcrumbs} siteUrl="https://devtoolkit.com" />

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-[var(--text-primary)]">Other Tools</h1>
    <p class="mt-2 text-[var(--text-secondary)]">
      Free online utility tools. All processing happens in your browser.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {tools.map((tool) => (
      <ToolCard {...tool} />
    ))}
  </div>
</BaseLayout>
