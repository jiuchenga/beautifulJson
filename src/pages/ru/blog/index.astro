---
// src/pages/en/blog/index.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/common/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const breadcrumbs = [
  { name: 'Home', url: '/ru' },
  { name: 'Blog', url: '/ru/blog' },
];

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Blog - DevToolkit Developer Tips & Tutorials"
  description="Developer tips, tutorials, and guides for using online developer tools effectively."
  path="/blog"
  siteUrl="https://devtoolkit.com"
  lang="ru"
>
  <Breadcrumb items={breadcrumbs} siteUrl="https://devtoolkit.com" />

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-[var(--text-primary)]">Blog</h1>
    <p class="mt-2 text-[var(--text-secondary)]">
      Developer tips, tutorials, and guides.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
    {posts.map((post) => (
      <a href={`/ru/blog/${post.id}`}
        class="group rounded-lg border border-[var(--border-primary)] bg-[var(--bg-secondary)] p-5 transition-all hover:border-[var(--accent-blue)]/50">
        <div class="mb-2 flex items-center gap-2 text-xs text-[var(--text-tertiary)]">
          <time datetime={post.data.date.toISOString().split('T')[0]}>
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </time>
          <span>·</span>
          <span>{post.data.author}</span>
        </div>
        <h2 class="text-lg font-semibold text-[var(--text-primary)] group-hover:text-[var(--accent-blue)]">{post.data.title}</h2>
        <p class="mt-2 text-sm text-[var(--text-secondary)]">{post.data.description}</p>
        {post.data.tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-1">
            {post.data.tags.map((tag: string) => (
              <span class="rounded-full bg-[var(--bg-tertiary)] px-2 py-0.5 text-[10px] text-[var(--text-tertiary)]">{tag}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>
</BaseLayout>
