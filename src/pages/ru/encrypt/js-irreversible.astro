---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsIrreversible from '@/components/tools/encrypt/JsIrreversible';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'Encryption', url: '/ru/category/encrypt' },
  { name: 'JS Irreversible Encryption', url: '/ru/encrypt/js-irreversible' },
];
---

<ToolLayout
  title="JS Irreversible Encryption - Free Online Tool | DevToolkit"
  description="Multi-layer JavaScript obfuscation encryption. Free online developer tool, no signup required."
  path="/encrypt/js-irreversible"
  siteUrl="https://devtoolkit.com"
  lang="ru"
  toolName="JS Irreversible Encryption"
  toolDescription="Multi-layer JavaScript obfuscation encryption"
  breadcrumbs={breadcrumbs}
>
  <JsIrreversible client:load />
</ToolLayout>
