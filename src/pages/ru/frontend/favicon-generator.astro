---
import ToolLayout from '@/layouts/ToolLayout.astro';
import FaviconGenerator from '@/components/tools/frontend/FaviconGenerator';

const breadcrumbs = [
  { name: 'Home', url: '/ru' },
  { name: 'Frontend / Design', url: '/ru/category/frontend' },
  { name: 'Favicon Generator', url: '/ru/frontend/favicon-generator' },
];
---

<ToolLayout
  title="Favicon Generator - Free Online Tool | DevToolkit"
  description="Generate favicon icons from text."
  path="/frontend/favicon-generator"
  siteUrl="https://devtoolkit.com"
  lang="ru"
  toolName="Favicon Generator"
  toolDescription="Generate favicon from text"
  breadcrumbs={breadcrumbs}
>
  <FaviconGenerator client:load />
</ToolLayout>
