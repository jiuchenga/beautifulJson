---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsFormatCompress from '@/components/tools/format/JsFormatCompress';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'Formatting', url: '/zh-tw/category/format' },
  { name: 'JS Format & Compress', url: '/zh-tw/format/js-format' },
];
---

<ToolLayout
  title="JS Format & Compress - Free Online Tool | DevToolkit"
  description="Beautify or compress JavaScript code. Free online developer tool, no signup required."
  path="/format/js-format"
  siteUrl="https://devtoolkit.com"
  lang="zh-tw"
  toolName="JS Format & Compress"
  toolDescription="Beautify or compress JavaScript code"
  breadcrumbs={breadcrumbs}
>
  <JsFormatCompress client:load />
</ToolLayout>
