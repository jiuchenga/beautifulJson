---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsObfuscateCompress from '@/components/tools/format/JsObfuscateCompress';

const breadcrumbs = [
  { name: 'Home', url: '/zh-tw' },
  { name: 'Formatting', url: '/zh-tw/category/format' },
  { name: 'JS Obfuscate & Compress', url: '/zh-tw/format/js-obfuscate-compress' },
];
---

<ToolLayout
  title="JS Obfuscate & Compress - Free Online Tool | DevToolkit"
  description="Combine compression and obfuscation for JavaScript. Free online developer tool."
  path="/format/js-obfuscate-compress"
  siteUrl="https://devtoolkit.com"
  lang="zh-tw"
  toolName="JS Obfuscate & Compress"
  toolDescription="Combine compression and obfuscation for JavaScript"
  breadcrumbs={breadcrumbs}
>
  <JsObfuscateCompress client:load />
</ToolLayout>
