---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsonToExcel from '@/components/tools/json/JsonToExcel';

const breadcrumbs = [
  { name: 'Home', url: '/zh-tw' },
  { name: 'JSON Tools', url: '/zh-tw/category/json' },
  { name: 'JSON to Excel', url: '/zh-tw/json/to-excel' },
];
---

<ToolLayout
  title="JSON to Excel - Export JSON to XLSX"
  description="Export JSON data to Excel (.xlsx) file with preview table. Free online developer tool."
  path="/json/to-excel"
  siteUrl="https://devtoolkit.com"
  lang="zh-tw"
  toolName="JSON to Excel"
  toolDescription="Export JSON data to Excel (.xlsx) file"
  breadcrumbs={breadcrumbs}
>
  <JsonToExcel client:load />
</ToolLayout>
