---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsonViewer from '@/components/tools/json/JsonViewer';

const breadcrumbs = [
  { name: 'Home', url: '/zh-tw' },
  { name: 'JSON Tools', url: '/zh-tw/category/json' },
  { name: 'JSON Viewer', url: '/zh-tw/json/viewer' },
];
---

<ToolLayout
  title="JSON Viewer - Interactive JSON Tree View"
  description="View JSON in a structured, interactive tree with collapsible nodes and type badges. Free online tool."
  path="/json/viewer"
  siteUrl="https://devtoolkit.com"
  lang="zh-tw"
  toolName="JSON Viewer"
  toolDescription="View JSON in a structured, interactive tree"
  breadcrumbs={breadcrumbs}
>
  <JsonViewer client:load />
</ToolLayout>
