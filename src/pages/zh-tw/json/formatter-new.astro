---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsonFormatterNew from '@/components/tools/json/JsonFormatterNew';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'JSON Tools', url: '/zh-tw/category/json' },
  { name: 'JSON Formatter (Enhanced)', url: '/zh-tw/json/formatter-new' },
];
---

<ToolLayout
  title="JSON Formatter (Enhanced) - Online JSON Beautifier with Type Analysis"
  description="Enhanced JSON formatter with data type display, array index, and syntax highlighting. Free online developer tool."
  path="/json/formatter-new"
  siteUrl="https://devtoolkit.com"
  lang="zh-tw"
  toolName="JSON Formatter (Enhanced)"
  toolDescription="Enhanced JSON formatter with type analysis and array index"
  breadcrumbs={breadcrumbs}
>
  <JsonFormatterNew client:load />
</ToolLayout>
