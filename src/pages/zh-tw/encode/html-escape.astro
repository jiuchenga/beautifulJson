---
import ToolLayout from '@/layouts/ToolLayout.astro';
import HtmlEscape from '@/components/tools/encode/HtmlEscape';

const breadcrumbs = [
  { name: 'Home', url: '/zh-tw' },
  { name: 'Encoding Conversion', url: '/zh-tw/category/encode' },
  { name: 'HTML Escape / Unescape', url: '/zh-tw/encode/html-escape' },
];
---

<ToolLayout
  title="HTML Escape / Unescape - Free Online Tool | DevToolkit"
  description="Encode or decode HTML entities. Free online developer tool, no signup required."
  path="/encode/html-escape"
  siteUrl="https://devtoolkit.com"
  lang="zh-tw"
  toolName="HTML Escape / Unescape"
  toolDescription="HTML entity encoding"
  breadcrumbs={breadcrumbs}
>
  <HtmlEscape client:load />
</ToolLayout>
