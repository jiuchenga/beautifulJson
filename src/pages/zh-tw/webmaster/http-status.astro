---
import ToolLayout from '@/layouts/ToolLayout.astro';
import HttpStatusCheck from '@/components/tools/webmaster/HttpStatusCheck';

const breadcrumbs = [
  { name: 'Home', url: '/zh-tw' },
  { name: 'Webmaster Tools', url: '/zh-tw/category/webmaster' },
  { name: 'HTTP Status Code Lookup', url: '/zh-tw/webmaster/http-status' },
];
---

<ToolLayout
  title="HTTP Status Code Lookup - Free Online Tool | DevToolkit"
  description="Look up HTTP status codes and their meanings."
  path="/webmaster/http-status"
  siteUrl="https://devtoolkit.com"
  lang="zh-tw"
  toolName="HTTP Status Code Lookup"
  toolDescription="HTTP status code reference"
  breadcrumbs={breadcrumbs}
>
  <HttpStatusCheck client:load />
</ToolLayout>
