---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsObfuscateEncrypt from '@/components/tools/format/JsObfuscateEncrypt';

const breadcrumbs = [
  { name: 'Home', url: '/fr' },
  { name: 'Formatting', url: '/fr/category/format' },
  { name: 'JS Code Obfuscate & Encrypt', url: '/fr/format/js-obfuscate-encrypt' },
];
---

<ToolLayout
  title="JS Code Obfuscate & Encrypt - Free Online Tool | DevToolkit"
  description="Obfuscate and encrypt JavaScript code. Free online developer tool, no signup required."
  path="/format/js-obfuscate-encrypt"
  siteUrl="https://devtoolkit.com"
  lang="fr"
  toolName="JS Code Obfuscate & Encrypt"
  toolDescription="Obfuscate and encrypt JavaScript code"
  breadcrumbs={breadcrumbs}
>
  <JsObfuscateEncrypt client:load />
</ToolLayout>
