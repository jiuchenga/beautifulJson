---
import ToolLayout from '@/layouts/ToolLayout.astro';
import HeadersCheck from '@/components/tools/webmaster/HeadersCheck';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'Webmaster Tools', url: '/fr/category/webmaster' },
  { name: 'HTTP Headers Check', url: '/fr/webmaster/http-headers' },
];
---

<ToolLayout
  title="HTTP Headers Check - Free Online Tool | DevToolkit"
  description="Check HTTP response headers."
  path="/webmaster/http-headers"
  siteUrl="https://devtoolkit.com"
  lang="fr"
  toolName="HTTP Headers Check"
  toolDescription="HTTP header inspection"
  breadcrumbs={breadcrumbs}
>
  <HeadersCheck client:load />
</ToolLayout>
