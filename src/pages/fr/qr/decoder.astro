---
import ToolLayout from '@/layouts/ToolLayout.astro';
import QrCodeDecoder from '@/components/tools/qr/QrCodeDecoder';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'QR Code Tools', url: '/fr/category/qr' },
  { name: 'QR Code Decoder', url: '/fr/qr/decoder' },
];
---

<ToolLayout
  title="QR Code Decoder - Free Online Tool | DevToolkit"
  description="Upload an image to decode the QR code."
  path="/qr/decoder"
  siteUrl="https://devtoolkit.com"
  lang="fr"
  toolName="QR Code Decoder"
  toolDescription="Upload/URL decode QR codes"
  breadcrumbs={breadcrumbs}
>
  <QrCodeDecoder client:load />
</ToolLayout>
