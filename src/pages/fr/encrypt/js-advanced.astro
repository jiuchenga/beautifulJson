---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsAdvancedEncrypt from '@/components/tools/encrypt/JsAdvancedEncrypt';

const breadcrumbs = [
  { name: 'Home', url: '/fr' },
  { name: 'Encryption', url: '/fr/category/encrypt' },
  { name: 'JS Encrypt (Advanced)', url: '/fr/encrypt/js-advanced' },
];
---

<ToolLayout
  title="JS Encrypt (Advanced) - Free Online Tool | DevToolkit"
  description="Advanced mixed encryption combining hex encoding and obfuscation. Free online developer tool, no signup required."
  path="/encrypt/js-advanced"
  siteUrl="https://devtoolkit.com"
  lang="fr"
  toolName="JS Encrypt (Advanced)"
  toolDescription="Advanced mixed encryption combining hex encoding and obfuscation"
  breadcrumbs={breadcrumbs}
>
  <JsAdvancedEncrypt client:load />
</ToolLayout>
