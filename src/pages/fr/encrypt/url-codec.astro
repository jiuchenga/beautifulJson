---
import ToolLayout from '@/layouts/ToolLayout.astro';
import UrlCodec from '@/components/tools/encrypt/UrlCodec';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'Encryption', url: '/fr/category/encrypt' },
  { name: 'URL Encode / Decode', url: '/fr/encrypt/url-codec' },
];
---

<ToolLayout
  title="URL Encode / Decode - Free Online Tool | DevToolkit"
  description="Encode or decode URLs with encodeURIComponent. Free online developer tool, no signup required."
  path="/encrypt/url-codec"
  siteUrl="https://devtoolkit.com"
  lang="fr"
  toolName="URL Encode / Decode"
  toolDescription="Encode or decode URLs with encodeURIComponent"
  breadcrumbs={breadcrumbs}
>
  <UrlCodec client:load />
</ToolLayout>
