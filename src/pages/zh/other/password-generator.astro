---
import ToolLayout from '@/layouts/ToolLayout.astro';
import PasswordGenerator from '@/components/tools/other/PasswordGenerator';

const breadcrumbs = [
  { name: 'Home', url: '/zh' },
  { name: 'Other Tools', url: '/zh/category/other' },
  { name: 'Password Generator', url: '/zh/other/password-generator' },
];
---

<ToolLayout
  title="Password Generator - Free Online Tool | DevToolkit"
  description="Generate secure random passwords."
  path="/other/password-generator"
  siteUrl="https://devtoolkit.com"
  lang="zh"
  toolName="Password Generator"
  toolDescription="Secure password generation"
  breadcrumbs={breadcrumbs}
>
  <PasswordGenerator client:load />
</ToolLayout>
