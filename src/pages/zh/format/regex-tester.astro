---
import ToolLayout from '@/layouts/ToolLayout.astro';
import RegexTester from '@/components/tools/format/RegexTester';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'Formatting', url: '/zh/category/format' },
  { name: 'Regex Tester', url: '/zh/format/regex-tester' },
];
---

<ToolLayout
  title="Regex Tester - Free Online Tool | DevToolkit"
  description="Test regular expressions with real-time matching and highlighting. Free online developer tool."
  path="/format/regex-tester"
  siteUrl="https://devtoolkit.com"
  lang="zh"
  toolName="Regex Tester"
  toolDescription="Test regular expressions with real-time matching"
  breadcrumbs={breadcrumbs}
>
  <RegexTester client:load />
</ToolLayout>
