---
// src/pages/en/json/formatter.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsonFormatter from '@/components/tools/json/JsonFormatter';
import ToolContent from '@/components/common/ToolContent.astro';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'JSON Tools', url: '/zh/category/json' },
  { name: 'JSON Formatter', url: '/zh/json/formatter' },
];

const features = [
  'Format and beautify JSON with configurable indentation',
  'Validate JSON with precise error position reporting',
  'Sort object keys alphabetically',
  'Download formatted JSON file',
  'Works entirely in your browser — no data sent to servers',
];

const steps = [
  { name: 'Paste JSON', text: 'Paste or type your JSON content in the input editor.' },
  { name: 'Configure options', text: 'Choose indent size (2 spaces, 4 spaces, or tab) and optionally enable key sorting.' },
  { name: 'Click Format', text: 'Press the Execute button to format your JSON.' },
  { name: 'Copy or Download', text: 'Copy the result to clipboard or download as a .json file.' },
];

const faq = [
  { question: 'Is this JSON formatter free?', answer: 'Yes, this tool is completely free to use with no signup required.' },
  { question: 'Is my data safe?', answer: 'All processing happens in your browser. Your data never leaves your device.' },
  { question: 'What is JSON formatting?', answer: 'JSON formatting (or beautification) adds proper indentation, line breaks, and spacing to make JSON readable by humans.' },
  { question: 'Can I format large JSON files?', answer: 'Yes, the tool can handle JSON files up to several MB. Performance may vary based on your device.' },
  { question: 'What does "Sort Keys" do?', answer: 'It alphabetically sorts all object keys in the JSON, which is useful for comparing two JSON objects.' },
];

const relatedTools = [
  { title: 'JSON Viewer', href: '/en/json/viewer' },
  { title: 'JSON Minifier', href: '/en/json/minifier' },
  { title: 'JSON Compare', href: '/en/json/compare' },
  { title: 'JSON Colorizer', href: '/en/json/colorizer' },
  { title: 'JSON Format Online', href: '/en/json/format-online' },
];
---

<ToolLayout
  title="JSON Formatter - Free Online JSON Beautifier | DevToolkit"
  description="Format, validate and beautify JSON online with syntax highlighting and error detection. Free developer tool, no signup required."
  path="/json/formatter"
  siteUrl="https://devtoolkit.com"
  lang="zh"
  toolName="JSON Formatter"
  toolDescription="Format, validate and beautify JSON with error detection"
  breadcrumbs={breadcrumbs}
>
  <JsonFormatter client:load />

  <!-- SEO Content Section -->
  <div class="mt-8 prose-content">
    <p class="text-sm text-[var(--text-secondary)]">
      Our JSON Formatter helps you format, validate, and beautify JSON data instantly. Simply paste your JSON,
      click Format, and get perfectly indented output. The tool validates your JSON and highlights errors with
      precise position information. It also supports sorting keys alphabetically and downloading formatted results.
    </p>
  </div>

  <ToolContent
    toolName="JSON Formatter"
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://devtoolkit.com"
  />
</ToolLayout>
