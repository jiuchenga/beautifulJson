---
import ToolLayout from '@/layouts/ToolLayout.astro';
import Stopwatch from '@/components/tools/life/Stopwatch';

const breadcrumbs = [
  { name: 'Home', url: '/zh' },
  { name: 'Life Tools', url: '/zh/category/life' },
  { name: 'Online Stopwatch', url: '/zh/life/stopwatch' },
];
---

<ToolLayout
  title="Online Stopwatch - Free Online Tool | DevToolkit"
  description="Simple online stopwatch with lap timer."
  path="/life/stopwatch"
  siteUrl="https://devtoolkit.com"
  lang="zh"
  toolName="Online Stopwatch"
  toolDescription="Timer with laps"
  breadcrumbs={breadcrumbs}
>
  <Stopwatch client:load />
</ToolLayout>
