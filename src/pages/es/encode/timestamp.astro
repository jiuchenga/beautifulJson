---
import ToolLayout from '@/layouts/ToolLayout.astro';
import TimestampConverter from '@/components/tools/encode/TimestampConverter';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'Encoding Conversion', url: '/es/category/encode' },
  { name: 'Unix Timestamp Converter', url: '/es/encode/timestamp' },
];
---

<ToolLayout
  title="Unix Timestamp Converter - Free Online Tool | DevToolkit"
  description="Convert between Unix timestamps and human-readable dates. Free online developer tool."
  path="/encode/timestamp"
  siteUrl="https://devtoolkit.com"
  lang="es"
  toolName="Unix Timestamp Converter"
  toolDescription="Timestamp ↔ date conversion"
  breadcrumbs={breadcrumbs}
>
  <TimestampConverter client:load />
</ToolLayout>
