---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsonFormatOnline from '@/components/tools/json/JsonFormatOnline';

const breadcrumbs = [
  { name: 'Home', url: '/es' },
  { name: 'JSON Tools', url: '/es/category/json' },
  { name: 'JSON Format Online', url: '/es/json/format-online' },
];
---

<ToolLayout
  title="JSON Format Online - Format and Validate JSON"
  description="Online JSON formatting and validation tool. Format, beautify, and validate JSON instantly. Free tool."
  path="/json/format-online"
  siteUrl="https://devtoolkit.com"
  lang="es"
  toolName="JSON Format Online"
  toolDescription="Online JSON formatting and validation tool"
  breadcrumbs={breadcrumbs}
>
  <JsonFormatOnline client:load />
</ToolLayout>
