---
import ToolLayout from '@/layouts/ToolLayout.astro';
import Md5Encrypt from '@/components/tools/encrypt/Md5Encrypt';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'Encryption', url: '/es/category/encrypt' },
  { name: 'MD5 Encrypt', url: '/es/encrypt/md5' },
];
---

<ToolLayout
  title="MD5 Encrypt - Free Online Tool | DevToolkit"
  description="Generate MD5 hash in 32-bit or 16-bit format. Free online developer tool, no signup required."
  path="/encrypt/md5"
  siteUrl="https://devtoolkit.com"
  lang="es"
  toolName="MD5 Encrypt"
  toolDescription="Generate MD5 hash in 32-bit or 16-bit format"
  breadcrumbs={breadcrumbs}
>
  <Md5Encrypt client:load />
</ToolLayout>
