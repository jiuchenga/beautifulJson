---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsManualDecrypt from '@/components/tools/encrypt/JsManualDecrypt';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'Encryption', url: '/es/category/encrypt' },
  { name: 'JS Manual Decryption', url: '/es/encrypt/js-manual-decrypt' },
];
---

<ToolLayout
  title="JS Manual Decryption - Free Online Tool | DevToolkit"
  description="Manually deobfuscate encrypted JavaScript code. Free online developer tool, no signup required."
  path="/encrypt/js-manual-decrypt"
  siteUrl="https://devtoolkit.com"
  lang="es"
  toolName="JS Manual Decryption"
  toolDescription="Manually deobfuscate encrypted JavaScript code"
  breadcrumbs={breadcrumbs}
>
  <JsManualDecrypt client:load />
</ToolLayout>
