---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsonCompressEscape from '@/components/tools/json/JsonCompressEscape';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'JSON Tools', url: '/en/category/json' },
  { name: 'JSON Compress/Escape', url: '/en/json/compress-escape' },
];
---

<ToolLayout
  title="JSON Compress / Escape - Minify and Escape JSON Online"
  description="Compress, escape, or Unicode encode your JSON strings. Free online developer tool."
  path="/json/compress-escape"
  siteUrl="https://devtoolkit.com"
  lang="en"
  toolName="JSON Compress/Escape"
  toolDescription="Compress, escape, or Unicode encode JSON strings"
  breadcrumbs={breadcrumbs}
>
  <JsonCompressEscape client:load />
</ToolLayout>
