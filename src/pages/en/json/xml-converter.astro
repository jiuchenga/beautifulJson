---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsonXmlConverter from '@/components/tools/json/JsonXmlConverter';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'JSON Tools', url: '/en/category/json' },
  { name: 'JSON ↔ XML Converter', url: '/en/json/xml-converter' },
];
---

<ToolLayout
  title="JSON ↔ XML Converter - Bidirectional Conversion Tool"
  description="Convert JSON to XML and XML to JSON online. Bidirectional conversion with customizable root element. Free developer tool."
  path="/json/xml-converter"
  siteUrl="https://devtoolkit.com"
  lang="en"
  toolName="JSON ↔ XML Converter"
  toolDescription="Bidirectional JSON to XML and XML to JSON conversion"
  breadcrumbs={breadcrumbs}
>
  <JsonXmlConverter client:load />
</ToolLayout>
