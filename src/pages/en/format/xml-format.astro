---
import ToolLayout from '@/layouts/ToolLayout.astro';
import XmlFormatCompress from '@/components/tools/format/XmlFormatCompress';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'Formatting', url: '/en/category/format' },
  { name: 'XML Format & Compress', url: '/en/format/xml-format' },
];
---

<ToolLayout
  title="XML Format & Compress - Free Online Tool | DevToolkit"
  description="Beautify or compress XML data. Free online developer tool, no signup required."
  path="/format/xml-format"
  siteUrl="https://devtoolkit.com"
  lang="en"
  toolName="XML Format & Compress"
  toolDescription="Beautify or compress XML data"
  breadcrumbs={breadcrumbs}
>
  <XmlFormatCompress client:load />
</ToolLayout>
