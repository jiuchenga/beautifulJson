---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsObfuscation from '@/components/tools/encrypt/JsObfuscation';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'Encryption', url: '/en/category/encrypt' },
  { name: 'JS Code Obfuscation', url: '/en/encrypt/js-obfuscation' },
];
---

<ToolLayout
  title="JS Code Obfuscation - Free Online Tool | DevToolkit"
  description="Obfuscate JavaScript code with base64 eval wrapping. Free online developer tool, no signup required."
  path="/encrypt/js-obfuscation"
  siteUrl="https://devtoolkit.com"
  lang="en"
  toolName="JS Code Obfuscation"
  toolDescription="Obfuscate JavaScript code with base64 eval wrapping"
  breadcrumbs={breadcrumbs}
>
  <JsObfuscation client:load />
</ToolLayout>
