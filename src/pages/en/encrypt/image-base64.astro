---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ImageToBase64 from '@/components/tools/encrypt/ImageToBase64';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'Encryption', url: '/en/category/encrypt' },
  { name: 'Image to Base64', url: '/en/encrypt/image-base64' },
];
---

<ToolLayout
  title="Image to Base64 - Free Online Tool | DevToolkit"
  description="Convert images to Base64 encoded strings. Free online developer tool, no signup required."
  path="/encrypt/image-base64"
  siteUrl="https://devtoolkit.com"
  lang="en"
  toolName="Image to Base64"
  toolDescription="Convert images to Base64 encoded strings"
  breadcrumbs={breadcrumbs}
>
  <ImageToBase64 client:load />
</ToolLayout>
