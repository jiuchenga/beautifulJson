---
import ToolLayout from '@/layouts/ToolLayout.astro';
import CssFormatCompress from '@/components/tools/format/CssFormatCompress';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'Formatting', url: '/de/category/format' },
  { name: 'CSS Format & Compress', url: '/de/format/css-format' },
];
---

<ToolLayout
  title="CSS Format & Compress - Free Online Tool | DevToolkit"
  description="Beautify or compress CSS code. Free online developer tool, no signup required."
  path="/format/css-format"
  siteUrl="https://devtoolkit.com"
  lang="de"
  toolName="CSS Format & Compress"
  toolDescription="Beautify or compress CSS code"
  breadcrumbs={breadcrumbs}
>
  <CssFormatCompress client:load />
</ToolLayout>
