---
import ToolLayout from '@/layouts/ToolLayout.astro';
import Base64Codec from '@/components/tools/encrypt/Base64Codec';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'Encryption', url: '/de/category/encrypt' },
  { name: 'Base64 Encode / Decode', url: '/de/encrypt/base64' },
];
---

<ToolLayout
  title="Base64 Encode / Decode - Free Online Tool | DevToolkit"
  description="Encode text to Base64 or decode Base64 to text. Free online developer tool, no signup required."
  path="/encrypt/base64"
  siteUrl="https://devtoolkit.com"
  lang="de"
  toolName="Base64 Encode / Decode"
  toolDescription="Encode text to Base64 or decode Base64 to text"
  breadcrumbs={breadcrumbs}
>
  <Base64Codec client:load />
</ToolLayout>
