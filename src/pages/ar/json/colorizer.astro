---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsonColorizer from '@/components/tools/json/JsonColorizer';

const breadcrumbs = [
  { name: 'Home', url: '/ar' },
  { name: 'JSON Tools', url: '/ar/category/json' },
  { name: 'JSON Colorizer', url: '/ar/json/colorizer' },
];
---

<ToolLayout
  title="JSON Colorizer - Syntax Highlighting for JSON"
  description="JSON syntax coloring with hierarchy preview. Colorize keys, strings, numbers, booleans and null values."
  path="/json/colorizer"
  siteUrl="https://devtoolkit.com"
  lang="ar"
  toolName="JSON Colorizer"
  toolDescription="JSON syntax coloring with hierarchy preview"
  breadcrumbs={breadcrumbs}
>
  <JsonColorizer client:load />
</ToolLayout>
