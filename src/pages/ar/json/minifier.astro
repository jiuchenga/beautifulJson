---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsonMinifier from '@/components/tools/json/JsonMinifier';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'JSON Tools', url: '/ar/category/json' },
  { name: 'JSON Minifier', url: '/ar/json/minifier' },
];
---

<ToolLayout
  title="JSON Minifier - Compress JSON Online"
  description="Compress JSON to a single line by removing whitespace. See size reduction statistics. Free online JSON minifier."
  path="/json/minifier"
  siteUrl="https://devtoolkit.com"
  lang="ar"
  toolName="JSON Minifier"
  toolDescription="Compress JSON to a single line by removing whitespace"
  breadcrumbs={breadcrumbs}
>
  <JsonMinifier client:load />
</ToolLayout>
