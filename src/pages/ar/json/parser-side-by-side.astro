---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsonParserSideBySide from '@/components/tools/json/JsonParserSideBySide';

const breadcrumbs = [
  { name: 'Home', url: '/ar' },
  { name: 'JSON Tools', url: '/ar/category/json' },
  { name: 'JSON Parser', url: '/ar/json/parser-side-by-side' },
];
---

<ToolLayout
  title="JSON Parser - Side by Side JSON Viewer"
  description="Parse JSON with side-by-side split view. Raw input on left, formatted output on right. Free online tool."
  path="/json/parser-side-by-side"
  siteUrl="https://devtoolkit.com"
  lang="ar"
  toolName="JSON Parser"
  toolDescription="Parse JSON with left-right split view"
  breadcrumbs={breadcrumbs}
>
  <JsonParserSideBySide client:load />
</ToolLayout>
