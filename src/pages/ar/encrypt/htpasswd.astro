---
import ToolLayout from '@/layouts/ToolLayout.astro';
import HtpasswdGenerator from '@/components/tools/encrypt/HtpasswdGenerator';

const breadcrumbs = [
  { name: 'Home', url: '/ar' },
  { name: 'Encryption', url: '/ar/category/encrypt' },
  { name: 'htpasswd Generator', url: '/ar/encrypt/htpasswd' },
];
---

<ToolLayout
  title="htpasswd Generator - Free Online Tool | DevToolkit"
  description="Generate Apache htpasswd entries. Free online developer tool, no signup required."
  path="/encrypt/htpasswd"
  siteUrl="https://devtoolkit.com"
  lang="ar"
  toolName="htpasswd Generator"
  toolDescription="Generate Apache htpasswd entries"
  breadcrumbs={breadcrumbs}
>
  <HtpasswdGenerator client:load />
</ToolLayout>
