---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsHexEncrypt from '@/components/tools/encrypt/JsHexEncrypt';

const breadcrumbs = [
  { name: 'Home', url: '/ar' },
  { name: 'Encryption', url: '/ar/category/encrypt' },
  { name: 'JS Encrypt (Hex)', url: '/ar/encrypt/js-hex' },
];
---

<ToolLayout
  title="JS Encrypt (Hex) - Free Online Tool | DevToolkit"
  description="Encode JavaScript to hexadecimal escape sequences. Free online developer tool, no signup required."
  path="/encrypt/js-hex"
  siteUrl="https://devtoolkit.com"
  lang="ar"
  toolName="JS Encrypt (Hex)"
  toolDescription="Encode JavaScript to hexadecimal escape sequences"
  breadcrumbs={breadcrumbs}
>
  <JsHexEncrypt client:load />
</ToolLayout>
