---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsHtmlConvert from '@/components/tools/encrypt/JsHtmlConvert';

const breadcrumbs = [
  { name: 'Home', url: '/ar' },
  { name: 'Encryption', url: '/ar/category/encrypt' },
  { name: 'JS ↔ HTML Convert', url: '/ar/encrypt/js-html-convert' },
];
---

<ToolLayout
  title="JS ↔ HTML Convert - Free Online Tool | DevToolkit"
  description="Convert between standalone JS and HTML script tags. Free online developer tool, no signup required."
  path="/encrypt/js-html-convert"
  siteUrl="https://devtoolkit.com"
  lang="ar"
  toolName="JS ↔ HTML Convert"
  toolDescription="Convert between standalone JS and HTML script tags"
  breadcrumbs={breadcrumbs}
>
  <JsHtmlConvert client:load />
</ToolLayout>
