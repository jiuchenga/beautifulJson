---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsAAEncode from '@/components/tools/encrypt/JsAAEncode';

const breadcrumbs = [
  { name: 'Home', url: '/ar' },
  { name: 'Encryption', url: '/ar/category/encrypt' },
  { name: 'JS AAEncode Encrypt', url: '/ar/encrypt/aaencode' },
];
---

<ToolLayout
  title="JS AAEncode Encrypt - Free Online Tool | DevToolkit"
  description="Encode JavaScript with anime emoticon characters. Free online developer tool, no signup required."
  path="/encrypt/aaencode"
  siteUrl="https://devtoolkit.com"
  lang="ar"
  toolName="JS AAEncode Encrypt"
  toolDescription="Encode JavaScript with anime emoticon characters"
  breadcrumbs={breadcrumbs}
>
  <JsAAEncode client:load />
</ToolLayout>
