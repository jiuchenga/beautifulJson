---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ImageViewer from '@/components/tools/frontend/ImageViewer';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'Frontend / Design', url: '/ar/category/frontend' },
  { name: 'Image Info Viewer', url: '/ar/frontend/image-info' },
];
---

<ToolLayout
  title="Image Info Viewer - Free Online Tool | DevToolkit"
  description="View image dimensions, size, type, and aspect ratio."
  path="/frontend/image-info"
  siteUrl="https://devtoolkit.com"
  lang="ar"
  toolName="Image Info Viewer"
  toolDescription="Image metadata viewer"
  breadcrumbs={breadcrumbs}
>
  <ImageViewer client:load />
</ToolLayout>
