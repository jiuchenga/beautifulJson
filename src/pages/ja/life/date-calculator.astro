---
import ToolLayout from '@/layouts/ToolLayout.astro';
import DateCalculator from '@/components/tools/life/DateCalculator';

const breadcrumbs = [
  { name: 'Home', url: '/ja' },
  { name: 'Life Tools', url: '/ja/category/life' },
  { name: 'Date Calculator', url: '/ja/life/date-calculator' },
];
---

<ToolLayout
  title="Date Calculator - Free Online Tool | DevToolkit"
  description="Calculate the interval between two dates."
  path="/life/date-calculator"
  siteUrl="https://devtoolkit.com"
  lang="ja"
  toolName="Date Calculator"
  toolDescription="Date interval calculation"
  breadcrumbs={breadcrumbs}
>
  <DateCalculator client:load />
</ToolLayout>
