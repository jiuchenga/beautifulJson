---
import ToolLayout from '@/layouts/ToolLayout.astro';
import RegexCodeGenerator from '@/components/tools/format/RegexCodeGenerator';

const breadcrumbs = [
  { name: 'Home', url: '/ja' },
  { name: 'Formatting', url: '/ja/category/format' },
  { name: 'Regex Code Generator', url: '/ja/format/regex-code-generator' },
];
---

<ToolLayout
  title="Regex Code Generator - Free Online Tool | DevToolkit"
  description="Generate regex code for JavaScript, Python, Java, Go, PHP, Ruby. Free online developer tool."
  path="/format/regex-code-generator"
  siteUrl="https://devtoolkit.com"
  lang="ja"
  toolName="Regex Code Generator"
  toolDescription="Generate regex code for multiple languages"
  breadcrumbs={breadcrumbs}
>
  <RegexCodeGenerator client:load />
</ToolLayout>
