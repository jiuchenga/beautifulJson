---
// src/pages/[lang]/encode/subnet-calculator.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import SubnetCalculator from '@/components/tools/encode/SubnetCalculator';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'encode/subnet-calculator';
const toolData = tools[toolKey];
const catData = categories['encode'];
const tc = getToolContent(langTyped, 'encode', 'subnet-calculator');

const breadcrumbs = [
  { name: common.home, url: `/beautifulJson/${lang}` },
  { name: catData?.name ?? 'encode', url: `/beautifulJson/${lang}/category/encode` },
  { name: toolData?.name ?? 'subnet-calculator', url: `/beautifulJson/${lang}/encode/subnet-calculator` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'subnet-calculator'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/encode/subnet-calculator"
  siteUrl="https://jiuchenga.github.io/beautifulJson"
  lang={langTyped}
  toolName={toolData?.name ?? 'subnet-calculator'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <SubnetCalculator client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'subnet-calculator'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://jiuchenga.github.io/beautifulJson"
    lang={langTyped}
  />
</ToolLayout>
