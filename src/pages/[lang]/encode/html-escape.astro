---
// src/pages/[lang]/encode/html-escape.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import HtmlEscape from '@/components/tools/encode/HtmlEscape';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'encode/html-escape';
const toolData = tools[toolKey];
const catData = categories['encode'];
const tc = getToolContent(langTyped, 'encode', 'html-escape');

const breadcrumbs = [
  { name: common.home, url: `${import.meta.env.BASE_URL}${lang}` },
  { name: catData?.name ?? 'encode', url: `${import.meta.env.BASE_URL}${lang}/category/encode` },
  { name: toolData?.name ?? 'html-escape', url: `${import.meta.env.BASE_URL}${lang}/encode/html-escape` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'html-escape'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/encode/html-escape"
  siteUrl="https://jiuchenga.github.io/beautifulJson"
  lang={langTyped}
  toolName={toolData?.name ?? 'html-escape'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <HtmlEscape client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'html-escape'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://jiuchenga.github.io/beautifulJson"
    lang={langTyped}
  />
</ToolLayout>
