---
// src/pages/[lang]/format/regex-tester.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import RegexTester from '@/components/tools/format/RegexTester';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'format/regex-tester';
const toolData = tools[toolKey];
const catData = categories['format'];
const tc = getToolContent(langTyped, 'format', 'regex-tester');

const breadcrumbs = [
  { name: common.home, url: `${import.meta.env.BASE_URL}${lang}` },
  { name: catData?.name ?? 'format', url: `${import.meta.env.BASE_URL}${lang}/category/format` },
  { name: toolData?.name ?? 'regex-tester', url: `${import.meta.env.BASE_URL}${lang}/format/regex-tester` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'regex-tester'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/format/regex-tester"
  siteUrl="https://beautifuljson.com"
  lang={langTyped}
  toolName={toolData?.name ?? 'regex-tester'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <RegexTester client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'regex-tester'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://beautifuljson.com"
    lang={langTyped}
  />
</ToolLayout>
