---
// src/pages/[lang]/format/js-obfuscate-compress.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import JsObfuscateCompress from '@/components/tools/format/JsObfuscateCompress';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'format/js-obfuscate-compress';
const toolData = tools[toolKey];
const catData = categories['format'];
const tc = getToolContent(langTyped, 'format', 'js-obfuscate-compress');

const breadcrumbs = [
  { name: common.home, url: `/beautifulJson/${lang}` },
  { name: catData?.name ?? 'format', url: `/beautifulJson/${lang}/category/format` },
  { name: toolData?.name ?? 'js-obfuscate-compress', url: `/beautifulJson/${lang}/format/js-obfuscate-compress` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'js-obfuscate-compress'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/format/js-obfuscate-compress"
  siteUrl="https://jiuchenga.github.io/beautifulJson"
  lang={langTyped}
  toolName={toolData?.name ?? 'js-obfuscate-compress'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <JsObfuscateCompress client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'js-obfuscate-compress'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://jiuchenga.github.io/beautifulJson"
    lang={langTyped}
  />
</ToolLayout>
