---
// src/pages/[lang]/format/js-format.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import JsFormatCompress from '@/components/tools/format/JsFormatCompress';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'format/js-format';
const toolData = tools[toolKey];
const catData = categories['format'];
const tc = getToolContent(langTyped, 'format', 'js-format');

const breadcrumbs = [
  { name: common.home, url: `/${lang}` },
  { name: catData?.name ?? 'format', url: `/${lang}/category/format` },
  { name: toolData?.name ?? 'js-format', url: `/${lang}/format/js-format` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'js-format'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/format/js-format"
  siteUrl="https://devtoolkit.com"
  lang={langTyped}
  toolName={toolData?.name ?? 'js-format'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <JsFormatCompress client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'js-format'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://devtoolkit.com"
    lang={langTyped}
  />
</ToolLayout>
