---
// src/pages/[lang]/life/date-calculator.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import DateCalculator from '@/components/tools/life/DateCalculator';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'life/date-calculator';
const toolData = tools[toolKey];
const catData = categories['life'];
const tc = getToolContent(langTyped, 'life', 'date-calculator');

const breadcrumbs = [
  { name: common.home, url: `${import.meta.env.BASE_URL}${lang}` },
  { name: catData?.name ?? 'life', url: `${import.meta.env.BASE_URL}${lang}/category/life` },
  { name: toolData?.name ?? 'date-calculator', url: `${import.meta.env.BASE_URL}${lang}/life/date-calculator` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'date-calculator'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/life/date-calculator"
  siteUrl="https://beautifuljson.com"
  lang={langTyped}
  toolName={toolData?.name ?? 'date-calculator'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <DateCalculator client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'date-calculator'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://beautifuljson.com"
    lang={langTyped}
  />
</ToolLayout>
