---
// src/pages/[lang]/life/world-time.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import WorldTime from '@/components/tools/life/WorldTime';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'life/world-time';
const toolData = tools[toolKey];
const catData = categories['life'];
const tc = getToolContent(langTyped, 'life', 'world-time');

const breadcrumbs = [
  { name: common.home, url: `/${lang}` },
  { name: catData?.name ?? 'life', url: `/${lang}/category/life` },
  { name: toolData?.name ?? 'world-time', url: `/${lang}/life/world-time` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'world-time'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/life/world-time"
  siteUrl="https://formatbeautifuljson.com"
  lang={langTyped}
  toolName={toolData?.name ?? 'world-time'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <WorldTime client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'world-time'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://formatbeautifuljson.com"
    lang={langTyped}
  />
</ToolLayout>
