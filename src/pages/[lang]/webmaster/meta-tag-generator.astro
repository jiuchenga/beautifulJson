---
// src/pages/[lang]/webmaster/meta-tag-generator.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import MetaTagGenerator from '@/components/tools/webmaster/MetaTagGenerator';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'webmaster/meta-tag-generator';
const toolData = tools[toolKey];
const catData = categories['webmaster'];
const tc = getToolContent(langTyped, 'webmaster', 'meta-tag-generator');

const breadcrumbs = [
  { name: common.home, url: `${import.meta.env.BASE_URL}${lang}` },
  { name: catData?.name ?? 'webmaster', url: `${import.meta.env.BASE_URL}${lang}/category/webmaster` },
  { name: toolData?.name ?? 'meta-tag-generator', url: `${import.meta.env.BASE_URL}${lang}/webmaster/meta-tag-generator` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'meta-tag-generator'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/webmaster/meta-tag-generator"
  siteUrl="https://jiuchenga.github.io/beautifulJson"
  lang={langTyped}
  toolName={toolData?.name ?? 'meta-tag-generator'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <MetaTagGenerator client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'meta-tag-generator'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://jiuchenga.github.io/beautifulJson"
    lang={langTyped}
  />
</ToolLayout>
