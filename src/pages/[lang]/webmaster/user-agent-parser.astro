---
// src/pages/[lang]/webmaster/user-agent-parser.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import UserAgentParser from '@/components/tools/webmaster/UserAgentParser';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'webmaster/user-agent-parser';
const toolData = tools[toolKey];
const catData = categories['webmaster'];
const tc = getToolContent(langTyped, 'webmaster', 'user-agent-parser');

const breadcrumbs = [
  { name: common.home, url: `/${lang}` },
  { name: catData?.name ?? 'webmaster', url: `/${lang}/category/webmaster` },
  { name: toolData?.name ?? 'user-agent-parser', url: `/${lang}/webmaster/user-agent-parser` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'user-agent-parser'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/webmaster/user-agent-parser"
  siteUrl="https://devtoolkit.com"
  lang={langTyped}
  toolName={toolData?.name ?? 'user-agent-parser'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <UserAgentParser client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'user-agent-parser'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://devtoolkit.com"
    lang={langTyped}
  />
</ToolLayout>
