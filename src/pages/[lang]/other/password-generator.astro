---
// src/pages/[lang]/other/password-generator.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import PasswordGenerator from '@/components/tools/other/PasswordGenerator';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'other/password-generator';
const toolData = tools[toolKey];
const catData = categories['other'];
const tc = getToolContent(langTyped, 'other', 'password-generator');

const breadcrumbs = [
  { name: common.home, url: `${import.meta.env.BASE_URL}${lang}` },
  { name: catData?.name ?? 'other', url: `${import.meta.env.BASE_URL}${lang}/category/other` },
  { name: toolData?.name ?? 'password-generator', url: `${import.meta.env.BASE_URL}${lang}/other/password-generator` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'password-generator'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/other/password-generator"
  siteUrl="https://beautifuljson.com"
  lang={langTyped}
  toolName={toolData?.name ?? 'password-generator'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <PasswordGenerator client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'password-generator'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://beautifuljson.com"
    lang={langTyped}
  />
</ToolLayout>
