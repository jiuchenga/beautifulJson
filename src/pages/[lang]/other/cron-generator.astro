---
// src/pages/[lang]/other/cron-generator.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import CronGenerator from '@/components/tools/other/CronGenerator';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'other/cron-generator';
const toolData = tools[toolKey];
const catData = categories['other'];
const tc = getToolContent(langTyped, 'other', 'cron-generator');

const breadcrumbs = [
  { name: common.home, url: `/beautifulJson/${lang}` },
  { name: catData?.name ?? 'other', url: `/beautifulJson/${lang}/category/other` },
  { name: toolData?.name ?? 'cron-generator', url: `/beautifulJson/${lang}/other/cron-generator` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'cron-generator'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/other/cron-generator"
  siteUrl="https://jiuchenga.github.io/beautifulJson"
  lang={langTyped}
  toolName={toolData?.name ?? 'cron-generator'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <CronGenerator client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'cron-generator'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://jiuchenga.github.io/beautifulJson"
    lang={langTyped}
  />
</ToolLayout>
