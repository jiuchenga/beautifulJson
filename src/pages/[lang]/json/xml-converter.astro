---
// src/pages/[lang]/json/xml-converter.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import JsonXmlConverter from '@/components/tools/json/JsonXmlConverter';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'json/xml-converter';
const toolData = tools[toolKey];
const catData = categories['json'];
const tc = getToolContent(langTyped, 'json', 'xml-converter');

const breadcrumbs = [
  { name: common.home, url: `/beautifulJson/${lang}` },
  { name: catData?.name ?? 'json', url: `/beautifulJson/${lang}/category/json` },
  { name: toolData?.name ?? 'xml-converter', url: `/beautifulJson/${lang}/json/xml-converter` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'xml-converter'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/json/xml-converter"
  siteUrl="https://jiuchenga.github.io/beautifulJson"
  lang={langTyped}
  toolName={toolData?.name ?? 'xml-converter'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <JsonXmlConverter client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'xml-converter'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://jiuchenga.github.io/beautifulJson"
    lang={langTyped}
  />
</ToolLayout>
