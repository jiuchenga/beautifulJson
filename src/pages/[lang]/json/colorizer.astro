---
// src/pages/[lang]/json/colorizer.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import JsonColorizer from '@/components/tools/json/JsonColorizer';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'json/colorizer';
const toolData = tools[toolKey];
const catData = categories['json'];
const tc = getToolContent(langTyped, 'json', 'colorizer');

const breadcrumbs = [
  { name: common.home, url: `${import.meta.env.BASE_URL}${lang}` },
  { name: catData?.name ?? 'json', url: `${import.meta.env.BASE_URL}${lang}/category/json` },
  { name: toolData?.name ?? 'colorizer', url: `${import.meta.env.BASE_URL}${lang}/json/colorizer` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'colorizer'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/json/colorizer"
  siteUrl="https://beautifuljson.com"
  lang={langTyped}
  toolName={toolData?.name ?? 'colorizer'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <JsonColorizer client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'colorizer'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://beautifuljson.com"
    lang={langTyped}
  />
</ToolLayout>
