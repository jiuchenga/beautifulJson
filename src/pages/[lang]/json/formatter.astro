---
// src/pages/[lang]/json/formatter.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import JsonFormatter from '@/components/tools/json/JsonFormatter';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'json/formatter';
const toolData = tools[toolKey];
const catData = categories['json'];
const tc = getToolContent(langTyped, 'json', 'formatter');

const breadcrumbs = [
  { name: common.home, url: `${import.meta.env.BASE_URL}${lang}` },
  { name: catData?.name ?? 'json', url: `${import.meta.env.BASE_URL}${lang}/category/json` },
  { name: toolData?.name ?? 'formatter', url: `${import.meta.env.BASE_URL}${lang}/json/formatter` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedSlugs = ['json/viewer', 'json/minifier', 'json/compare', 'json/colorizer', 'json/format-online'];
const relatedTools: { title: string; href: string }[] = relatedSlugs
  .map(slug => ({ title: tools[slug]?.name ?? slug.split('/')[1], href: `${import.meta.env.BASE_URL}${lang}/${slug}` }));
---

<ToolLayout
  title={`${toolData?.name ?? 'formatter'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/json/formatter"
  siteUrl="https://devtoolkit.com"
  lang={langTyped}
  toolName={toolData?.name ?? 'formatter'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <JsonFormatter client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />
  <ToolContent
    toolName={toolData?.name ?? 'formatter'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://devtoolkit.com"
    lang={langTyped}
  />
</ToolLayout>
