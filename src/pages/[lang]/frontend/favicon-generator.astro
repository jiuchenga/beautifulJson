---
// src/pages/[lang]/frontend/favicon-generator.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import FaviconGenerator from '@/components/tools/frontend/FaviconGenerator';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'frontend/favicon-generator';
const toolData = tools[toolKey];
const catData = categories['frontend'];
const tc = getToolContent(langTyped, 'frontend', 'favicon-generator');

const breadcrumbs = [
  { name: common.home, url: `${import.meta.env.BASE_URL}${lang}` },
  { name: catData?.name ?? 'frontend', url: `${import.meta.env.BASE_URL}${lang}/category/frontend` },
  { name: toolData?.name ?? 'favicon-generator', url: `${import.meta.env.BASE_URL}${lang}/frontend/favicon-generator` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'favicon-generator'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/frontend/favicon-generator"
  siteUrl="https://beautifuljson.com"
  lang={langTyped}
  toolName={toolData?.name ?? 'favicon-generator'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <FaviconGenerator client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'favicon-generator'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://beautifuljson.com"
    lang={langTyped}
  />
</ToolLayout>
