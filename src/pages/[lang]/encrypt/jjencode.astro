---
// src/pages/[lang]/encrypt/jjencode.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import JsJJEncode from '@/components/tools/encrypt/JsJJEncode';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'encrypt/jjencode';
const toolData = tools[toolKey];
const catData = categories['encrypt'];
const tc = getToolContent(langTyped, 'encrypt', 'jjencode');

const breadcrumbs = [
  { name: common.home, url: `/${lang}` },
  { name: catData?.name ?? 'encrypt', url: `/${lang}/category/encrypt` },
  { name: toolData?.name ?? 'jjencode', url: `/${lang}/encrypt/jjencode` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'jjencode'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/encrypt/jjencode"
  siteUrl="https://devtoolkit.com"
  lang={langTyped}
  toolName={toolData?.name ?? 'jjencode'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <JsJJEncode client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'jjencode'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://devtoolkit.com"
    lang={langTyped}
  />
</ToolLayout>
