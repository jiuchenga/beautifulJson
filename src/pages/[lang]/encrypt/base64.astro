---
// src/pages/[lang]/encrypt/base64.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import Base64Codec from '@/components/tools/encrypt/Base64Codec';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'encrypt/base64';
const toolData = tools[toolKey];
const catData = categories['encrypt'];
const tc = getToolContent(langTyped, 'encrypt', 'base64');

const breadcrumbs = [
  { name: common.home, url: `${import.meta.env.BASE_URL}${lang}` },
  { name: catData?.name ?? 'encrypt', url: `${import.meta.env.BASE_URL}${lang}/category/encrypt` },
  { name: toolData?.name ?? 'base64', url: `${import.meta.env.BASE_URL}${lang}/encrypt/base64` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'base64'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/encrypt/base64"
  siteUrl="https://jiuchenga.github.io/beautifulJson"
  lang={langTyped}
  toolName={toolData?.name ?? 'base64'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <Base64Codec client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'base64'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://jiuchenga.github.io/beautifulJson"
    lang={langTyped}
  />
</ToolLayout>
