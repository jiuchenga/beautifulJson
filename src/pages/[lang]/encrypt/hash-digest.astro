---
// src/pages/[lang]/encrypt/hash-digest.astro
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolContent from '@/components/common/ToolContent.astro';
import { languages, type Lang } from '@/i18n/ui';
import { getCategories, getCommon, getTools, getToolContent } from '@/i18n/t';
import HashDigest from '@/components/tools/encrypt/HashDigest';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langTyped = lang as Lang;
const common = getCommon(langTyped);
const categories = getCategories(langTyped);
const tools = getTools(langTyped);
const toolKey = 'encrypt/hash-digest';
const toolData = tools[toolKey];
const catData = categories['encrypt'];
const tc = getToolContent(langTyped, 'encrypt', 'hash-digest');

const breadcrumbs = [
  { name: common.home, url: `/${lang}` },
  { name: catData?.name ?? 'encrypt', url: `/${lang}/category/encrypt` },
  { name: toolData?.name ?? 'hash-digest', url: `/${lang}/encrypt/hash-digest` },
];

const features = tc?.features ?? [];

const steps = tc?.steps ?? [];

const faq = tc?.faq ?? [];

const relatedTools: { title: string; href: string }[] = [

];
---

<ToolLayout
  title={`${toolData?.name ?? 'hash-digest'} - Free Online Tool | BeautifulJSON`}
  description={toolData?.description ?? ''}
  path="/encrypt/hash-digest"
  siteUrl="https://formatbeautifuljson.com"
  lang={langTyped}
  toolName={toolData?.name ?? 'hash-digest'}
  toolDescription={toolData?.description ?? ''}
  breadcrumbs={breadcrumbs}
>
  <HashDigest client:load lang={langTyped} title={toolData?.name ?? ''} description={toolData?.description ?? ''} />

  <ToolContent
    toolName={toolData?.name ?? 'hash-digest'}
    features={features}
    steps={steps}
    faq={faq}
    relatedTools={relatedTools}
    siteUrl="https://formatbeautifuljson.com"
    lang={langTyped}
  />
</ToolLayout>
