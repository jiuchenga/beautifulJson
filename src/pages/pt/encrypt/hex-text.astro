---
import ToolLayout from '@/layouts/ToolLayout.astro';
import HexTextConverter from '@/components/tools/encrypt/HexTextConverter';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'Encryption', url: '/pt/category/encrypt' },
  { name: 'Hex ↔ Text Converter', url: '/pt/encrypt/hex-text' },
];
---

<ToolLayout
  title="Hex ↔ Text Converter - Free Online Tool | DevToolkit"
  description="Convert between hexadecimal strings and text. Free online developer tool, no signup required."
  path="/encrypt/hex-text"
  siteUrl="https://devtoolkit.com"
  lang="pt"
  toolName="Hex ↔ Text Converter"
  toolDescription="Convert between hexadecimal strings and text"
  breadcrumbs={breadcrumbs}
>
  <HexTextConverter client:load />
</ToolLayout>
