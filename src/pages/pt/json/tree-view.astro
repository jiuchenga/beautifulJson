---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsonTreeView from '@/components/tools/json/JsonTreeView';

const breadcrumbs = [
  { name: 'Home', url: '/pt' },
  { name: 'JSON Tools', url: '/pt/category/json' },
  { name: 'JSON Tree View', url: '/pt/json/tree-view' },
];
---

<ToolLayout
  title="JSON Tree Viewer - Interactive JSON Tree View"
  description="View JSON in an interactive tree with collapse/expand, type tags, and depth navigation. Free online tool."
  path="/json/tree-view"
  siteUrl="https://devtoolkit.com"
  lang="pt"
  toolName="JSON Tree View"
  toolDescription="Interactive tree view with collapse/expand and type info"
  breadcrumbs={breadcrumbs}
>
  <JsonTreeView client:load />
</ToolLayout>
