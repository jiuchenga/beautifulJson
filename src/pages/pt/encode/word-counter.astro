---
import ToolLayout from '@/layouts/ToolLayout.astro';
import WordCounter from '@/components/tools/encode/WordCounter';

const breadcrumbs = [
  { name: 'Home', url: '/pt' },
  { name: 'Encoding Conversion', url: '/pt/category/encode' },
  { name: 'Online Word Counter', url: '/pt/encode/word-counter' },
];
---

<ToolLayout
  title="Online Word Counter - Free Online Tool | DevToolkit"
  description="Count characters, words, lines, paragraphs, and bytes. Free online developer tool."
  path="/encode/word-counter"
  siteUrl="https://devtoolkit.com"
  lang="pt"
  toolName="Online Word Counter"
  toolDescription="Character/word count"
  breadcrumbs={breadcrumbs}
>
  <WordCounter client:load />
</ToolLayout>
