---
// src/pages/en/category/frontend.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/common/Breadcrumb.astro';
import ToolCard from '@/components/common/ToolCard.astro';

const breadcrumbs = [
  { name: 'Home', url: '/pt' },
  { name: 'Frontend / Design', url: '/pt/category/frontend' },
];

const tools = [
  { title: 'Web Color Picker', description: 'HEX, RGB, HSL conversion', href: '/pt/frontend/color-picker', icon: '🎨' },
  { title: 'Image Info Viewer', description: 'Dimensions, size, type', href: '/pt/frontend/image-info', icon: '🖼️' },
  { title: 'Favicon Generator', description: 'Generate favicon from text', href: '/pt/frontend/favicon-generator', icon: '⭐' },
];
---

<BaseLayout
  title="Frontend / Design Tools - Free Online Color & Image Utilities"
  description="Free online frontend tools: color picker, image info viewer, favicon generator."
  path="/category/frontend"
  siteUrl="https://devtoolkit.com"
  lang="pt"
>
  <Breadcrumb items={breadcrumbs} siteUrl="https://devtoolkit.com" />

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-[var(--text-primary)]">Frontend / Design Tools</h1>
    <p class="mt-2 text-[var(--text-secondary)]">
      Free online frontend and design utilities. All processing happens in your browser.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {tools.map((tool) => (
      <ToolCard {...tool} />
    ))}
  </div>
</BaseLayout>
