---
// src/pages/en/index.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import ToolCard from '@/components/common/ToolCard.astro';

const categories = [
  { slug: 'json', name: 'JSON Tools', icon: '{ }', count: 15, description: 'Format, validate, minify, convert JSON data' },
  { slug: 'encrypt', name: 'Encryption / Decryption', icon: '🔐', count: 24, description: 'AES, DES, MD5, SHA, Base64 encryption tools' },
  { slug: 'format', name: 'Compression / Formatting', icon: '📐', count: 9, description: 'Code formatting, compression, regex tools' },
  { slug: 'encode', name: 'Encoding Conversion', icon: '🔄', count: 5, description: 'Timestamp, HTML escape, unit conversion' },
  { slug: 'qr', name: 'QR Code Tools', icon: '📱', count: 5, description: 'Generate, decode, and customize QR codes' },
  { slug: 'webmaster', name: 'Webmaster Tools', icon: '🌐', count: 5, description: 'HTTP status, robots.txt, meta tags' },
  { slug: 'frontend', name: 'Frontend / Design', icon: '🎨', count: 3, description: 'Color picker, image info, favicon generator' },
  { slug: 'life', name: 'Life Tools', icon: '🕐', count: 4, description: 'Date calculator, stopwatch, world time' },
  { slug: 'other', name: 'Other Tools', icon: '🛠️', count: 2, description: 'Password generator, cron expression' },
];

const hotTools = [
  { title: 'JSON Formatter', description: 'Format and beautify JSON', href: '/pt/json/formatter', icon: '{ }' },
  { title: 'Encrypt / Decrypt', description: 'AES, DES, TripleDES encryption', href: '/pt/encrypt/aes', icon: '🔐' },
  { title: 'Base64 Encode/Decode', description: 'Text Base64 encoding', href: '/pt/encrypt/base64', icon: '🔐' },
  { title: 'JSON Viewer', description: 'Interactive JSON tree view', href: '/pt/json/viewer', icon: '{ }' },
  { title: 'Hash / Digest', description: 'MD5, SHA-256, SHA-512', href: '/pt/encrypt/hash-digest', icon: '🔐' },
];
---

<BaseLayout
  title="DevToolkit - 160+ Free Online Developer Tools"
  description="Free online developer tools: JSON formatter, encryption, encoding, QR code, webmaster tools and more. No signup required."
  path="/"
  siteUrl="https://devtoolkit.com"
  lang="pt"
>
  <!-- Hero Section -->
  <section class="py-12 text-center">
    <h1 class="text-4xl font-bold text-[var(--text-primary)]">
      <span class="font-mono text-[var(--accent-blue)]">{'{ }'}</span> DevToolkit
    </h1>
    <p class="mt-3 text-lg text-[var(--text-secondary)]">
      160+ free online developer tools. No signup required.
    </p>
    <p class="mt-1 text-sm text-[var(--text-tertiary)]">
      All processing happens in your browser. Your data never leaves your device.
    </p>
  </section>

  <!-- Hot Tools -->
  <section class="mb-12">
    <h2 class="mb-4 text-lg font-semibold text-[var(--text-primary)]">Popular Tools</h2>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5">
      {hotTools.map((tool) => (
        <ToolCard {...tool} />
      ))}
    </div>
  </section>

  <!-- Categories -->
  <section>
    <h2 class="mb-4 text-lg font-semibold text-[var(--text-primary)]">All Categories</h2>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {categories.map((cat) => (
        <a
          href={`/pt/category/${cat.slug}`}
          class="group flex items-center gap-4 rounded-lg border border-[var(--border-primary)] bg-[var(--bg-secondary)] p-4 transition-all hover:border-[var(--accent-blue)]/50"
        >
          <span class="text-2xl">{cat.icon}</span>
          <div>
            <h3 class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[var(--accent-blue)]">{cat.name}</h3>
            <p class="text-xs text-[var(--text-secondary)]">{cat.description}</p>
            <span class="mt-1 inline-block rounded-full bg-[var(--bg-tertiary)] px-2 py-0.5 text-[10px] text-[var(--text-tertiary)]">{cat.count} tools</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
