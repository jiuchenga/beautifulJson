---
import ToolLayout from '@/layouts/ToolLayout.astro';
import MetaTagGenerator from '@/components/tools/webmaster/MetaTagGenerator';

const breadcrumbs = [
  { name: 'Home', url: '/en' },
  { name: 'Webmaster Tools', url: '/pt/category/webmaster' },
  { name: 'Meta Tag Generator', url: '/pt/webmaster/meta-tag-generator' },
];
---

<ToolLayout
  title="Meta Tag Generator - Free Online Tool | DevToolkit"
  description="Generate HTML meta tags for SEO."
  path="/webmaster/meta-tag-generator"
  siteUrl="https://devtoolkit.com"
  lang="pt"
  toolName="Meta Tag Generator"
  toolDescription="SEO meta tag generator"
  breadcrumbs={breadcrumbs}
>
  <MetaTagGenerator client:load />
</ToolLayout>
