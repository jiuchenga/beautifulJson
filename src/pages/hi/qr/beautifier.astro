---
import ToolLayout from '@/layouts/ToolLayout.astro';
import QrCodeBeautifier from '@/components/tools/qr/QrCodeBeautifier';

const breadcrumbs = [
  { name: 'Home', url: '/hi' },
  { name: 'QR Code Tools', url: '/hi/category/qr' },
  { name: 'QR Code Beautifier', url: '/hi/qr/beautifier' },
];
---

<ToolLayout
  title="QR Code Beautifier - Free Online Tool | DevToolkit"
  description="Generate styled QR codes with custom colors and size."
  path="/qr/beautifier"
  siteUrl="https://devtoolkit.com"
  lang="hi"
  toolName="QR Code Beautifier"
  toolDescription="Style customization for QR codes"
  breadcrumbs={breadcrumbs}
>
  <QrCodeBeautifier client:load />
</ToolLayout>
