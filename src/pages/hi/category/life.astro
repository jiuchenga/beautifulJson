---
// src/pages/en/category/life.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/common/Breadcrumb.astro';
import ToolCard from '@/components/common/ToolCard.astro';

const breadcrumbs = [
  { name: 'Home', url: '/hi' },
  { name: 'Life Tools', url: '/hi/category/life' },
];

const tools = [
  { title: 'Date Calculator', description: 'Date interval calculation', href: '/hi/life/date-calculator', icon: '📅' },
  { title: 'Online Stopwatch', description: 'Timer with laps', href: '/hi/life/stopwatch', icon: '⏱️' },
  { title: 'World Time', description: 'Current world time', href: '/hi/life/world-time', icon: '🌍' },
  { title: 'Text ↔ Morse Code', description: 'Morse code encoding', href: '/hi/life/morse-code', icon: '📡' },
];
---

<BaseLayout
  title="Life Tools - Free Online Date, Time & Everyday Utilities"
  description="Free online life tools: date calculator, stopwatch, world time, Morse code and more."
  path="/category/life"
  siteUrl="https://devtoolkit.com"
  lang="hi"
>
  <Breadcrumb items={breadcrumbs} siteUrl="https://devtoolkit.com" />

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-[var(--text-primary)]">Life Tools</h1>
    <p class="mt-2 text-[var(--text-secondary)]">
      Free online everyday utilities. All processing happens in your browser.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {tools.map((tool) => (
      <ToolCard {...tool} />
    ))}
  </div>
</BaseLayout>
