---
// src/pages/en/category/format.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/common/Breadcrumb.astro';
import ToolCard from '@/components/common/ToolCard.astro';

const breadcrumbs = [
  { name: 'Home', url: '/hi' },
  { name: 'Compression / Formatting', url: '/hi/category/format' },
];

const tools = [
  { title: 'JS/HTML Format & Compress', description: 'Smart mixed code formatting', href: '/hi/format/js-html-format', icon: '📐' },
  { title: 'JS Format & Compress', description: 'Beautify + compress JavaScript', href: '/hi/format/js-format', icon: '📐' },
  { title: 'CSS Format & Compress', description: 'Beautify + compress CSS', href: '/hi/format/css-format', icon: '📐' },
  { title: 'XML Format & Compress', description: 'XML beautify + compress', href: '/hi/format/xml-format', icon: '📐' },
  { title: 'SQL Format & Compress', description: 'SQL beautify + compress', href: '/hi/format/sql-format', icon: '📐' },
  { title: 'JS Code Obfuscate & Encrypt', description: 'Obfuscation + encryption', href: '/hi/format/js-obfuscate-encrypt', icon: '🔒' },
  { title: 'JS Obfuscate & Compress', description: 'Obfuscation + compression', href: '/hi/format/js-obfuscate-compress', icon: '🔒' },
  { title: 'Regex Tester', description: 'Online regex matching test', href: '/hi/format/regex-tester', icon: '🔍' },
  { title: 'Regex Code Generator', description: 'JS/PHP/Go/Java/Ruby/Python', href: '/hi/format/regex-code-generator', icon: '🔍' },
];
---

<BaseLayout
  title="Compression / Formatting Tools - 9 Free Online Code Utilities"
  description="9 free online code formatting tools: JS, CSS, HTML, XML, SQL formatter, regex tester and more."
  path="/category/format"
  siteUrl="https://devtoolkit.com"
  lang="hi"
>
  <Breadcrumb items={breadcrumbs} siteUrl="https://devtoolkit.com" />

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-[var(--text-primary)]">Compression / Formatting Tools</h1>
    <p class="mt-2 text-[var(--text-secondary)]">
      9 free online code formatting and regex utilities. All processing happens in your browser.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {tools.map((tool) => (
      <ToolCard {...tool} />
    ))}
  </div>
</BaseLayout>
