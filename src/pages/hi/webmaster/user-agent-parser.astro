---
import ToolLayout from '@/layouts/ToolLayout.astro';
import UserAgentParser from '@/components/tools/webmaster/UserAgentParser';

const breadcrumbs = [
  { name: 'Home', url: '/hi' },
  { name: 'Webmaster Tools', url: '/hi/category/webmaster' },
  { name: 'User Agent Parser', url: '/hi/webmaster/user-agent-parser' },
];
---

<ToolLayout
  title="User Agent Parser - Free Online Tool | DevToolkit"
  description="Parse and analyze User-Agent strings."
  path="/webmaster/user-agent-parser"
  siteUrl="https://devtoolkit.com"
  lang="hi"
  toolName="User Agent Parser"
  toolDescription="User-agent string analysis"
  breadcrumbs={breadcrumbs}
>
  <UserAgentParser client:load />
</ToolLayout>
